{
  "name": "parent-activity-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "activities:expanded": "node scripts/build-expanded-activities-seed.js",
    "activities:best-start": "node scripts/import-waltham-forest-best-start.js",
    "activities:google-e10": "node scripts/build-google-places-e10.js",
    "activities:images": "node scripts/enrich-activity-images.js --audit",
    "activities:images:missing": "node scripts/enrich-activity-images.js --missing-only",
    "activities:locations": "node scripts/enrich-activity-locations.js",
    "activities:family-cafes": "node scripts/build-high-rated-family-cafes.js",
    "activities:eventbrite-baby": "node scripts/import-eventbrite-baby-london.js",
    "activities:fever-family": "node scripts/import-fever-london-family.js",
    "activities:fever-availability": "node scripts/enrich-fever-availability.js",
    "activities:normalize-event-names": "node scripts/normalize-event-names.js",
    "activities:london-chains": "node scripts/build-london-chain-places.js",
    "activities:london-parks": "node scripts/build-london-parks.js",
    "activities:repair-happity-links": "node scripts/repair-happity-links.js",
    "activities:happity": "node scripts/import-happity-schedules.js",
    "activities:audit-swipe": "node scripts/audit-swipe-visibility.js",
    "activities:audit-plan-filters": "node scripts/audit-activity-plan-filters.js",
    "activities:audit-cards": "node scripts/audit-activity-card-readiness.js",
    "activities:repair-websites": "node scripts/repair-broken-activity-websites.js",
    "activities:weekly": "node scripts/run-weekly-activity-import.js",
    "activities:weekly:apply": "node scripts/run-weekly-activity-import.js --apply",
    "render:download": "node scripts/prepare-render-download.js",
    "cap:sync": "npm run build && npx cap sync",
    "android:add": "npx cap add android",
    "android:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-android.ps1",
    "android:open": "npx cap open android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:bundle": "npm run android:sync && cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@supabase/supabase-js": "^2.53.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.11"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0"
  }
}
